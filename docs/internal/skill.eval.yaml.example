version: 1
skill_name: email-digest
thresholds:
  benchmark_accuracy_min: 0.8
  trigger_recall_min: 0.75
benchmark_cases:
  - prompt: "Check my email every morning"
    expected_skill: "email-digest"
  - prompt: "Send me a daily inbox digest"
    expected_skill: "email-digest"
trigger_cases:
  - "check my email every morning"
  - "send daily inbox summary"
