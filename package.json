{
  "name": "tandem",
  "private": true,
  "version": "0.6.4",
  "type": "module",
  "scripts": {
    "desktop:dev": "pnpm -C apps/tandem-desktop tauri dev",
    "desktop:build": "pnpm -C apps/tandem-desktop tauri build",
    "desktop:preview": "pnpm -C apps/tandem-desktop preview",
    "desktop:install": "pnpm -C apps/tandem-desktop install",
    "engine:stop:windows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-Process | Where-Object { $_.ProcessName -in @('tandem-engine','tandem','tandem-tui') } | Stop-Process -Force -ErrorAction SilentlyContinue\"",
    "engine:build": "cargo build -p tandem-ai",
    "agents:catalog:refresh": "node scripts/generate-agent-catalog.mjs",
    "agents:catalog:test": "node --test scripts/agent-catalog.test.mjs",
    "engine:start": "cargo run -p tandem-ai --bin tandem-engine -- serve --host 127.0.0.1 --port 39731",
    "engine:test": "cargo test -p tandem-server -p tandem-core -p tandem-ai",
    "test:blackboard": "pnpm -C apps/tandem-desktop test:blackboard",
    "incident-monitor:fixture:test": "node --test scripts/incident-monitor-external-log-intake-fixture.test.mjs",
    "incident-monitor:terminology": "node scripts/check-incident-monitor-terminology.mjs",
    "engine:smoke:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/engine_smoke.ps1",
    "engine:smoke:unix": "bash ./scripts/engine_smoke.sh",
    "docs:parity": "node scripts/verify-docs-parity.mjs",
    "i18n:parity": "node scripts/verify-i18n-parity.mjs",
    "lint:desktop": "pnpm -C apps/tandem-desktop lint",
    "format:desktop": "pnpm -C apps/tandem-desktop format",
    "format:desktop:check": "pnpm -C apps/tandem-desktop format:check",
    "check-secrets": "node scripts/check-secrets.js",
    "download-sidecar": "node scripts/download-sidecar.js",
    "desktop:dev:clean": "pnpm -C apps/tandem-desktop tauri:dev:clean"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm -C apps/tandem-desktop exec eslint --fix",
      "pnpm -C apps/tandem-desktop exec prettier --write",
      "node scripts/check-secrets.js"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt --edition 2021",
      "node scripts/check-secrets.js"
    ]
  }
}
