# Tandem Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# Enable development mode
TANDEM_DEV_MODE=false

# Default provider: openrouter, anthropic, openai, ollama
TANDEM_DEFAULT_PROVIDER=openrouter

# Runtime auth and signed tenant context assertions.
# local_single_tenant is for desktop/local engines. Hosted and enterprise
# deployments should use hosted_single_tenant or enterprise_required plus a
# context assertion public keyring.
# TANDEM_RUNTIME_AUTH_MODE=local_single_tenant
# TANDEM_CONTEXT_ASSERTION_PUBLIC_KEYS={"ctx-2026-06":{"publicKey":"base64url-ed25519-public-key","purpose":"context_assertion","status":"active","notAfterMs":1783892000000}}
# TANDEM_CONTEXT_ASSERTION_PUBLIC_KEYS_FILE=/etc/tandem/context-assertion-keys.json
# TANDEM_CONTEXT_ASSERTION_ISSUER=tandem-web
# TANDEM_CONTEXT_ASSERTION_AUDIENCE=tandem-runtime
# TANDEM_CONTEXT_ASSERTION_MAX_FUTURE_SKEW_MS=10000
# TANDEM_CONTEXT_ASSERTION_REPLAY_MODE=bound
# Retain canonical runtime event replay rows for this many days. Set to 0 to
# disable cleanup.
# TANDEM_RUNTIME_EVENT_LOG_RETENTION_DAYS=30

# Note: API keys should be entered through the app Settings UI
# They are stored in an encrypted Stronghold vault

# Tool guard budgets
# Default install behavior enforces per-run tool guard budgets.
TANDEM_DISABLE_TOOL_GUARD_BUDGETS=0
TANDEM_TOOL_ROUTER_ENABLED=0
TANDEM_PROMPT_CONTEXT_HOOK_TIMEOUT_MS=5000
TANDEM_PROVIDER_STREAM_CONNECT_TIMEOUT_MS=90000
TANDEM_PROVIDER_STREAM_IDLE_TIMEOUT_MS=90000
TANDEM_PERMISSION_WAIT_TIMEOUT_MS=15000
TANDEM_TOOL_EXEC_TIMEOUT_MS=45000
TANDEM_BASH_TIMEOUT_MS=30000
# Incident Monitor (disabled by default)
# TANDEM_INCIDENT_MONITOR_ENABLED=0
# TANDEM_INCIDENT_MONITOR_REPO=owner/repo
# TANDEM_INCIDENT_MONITOR_MCP_SERVER=github
# TANDEM_INCIDENT_MONITOR_PROVIDER_PREFERENCE=auto
# TANDEM_INCIDENT_MONITOR_PROVIDER_ID=openrouter
# TANDEM_INCIDENT_MONITOR_MODEL_ID=openai/gpt-4.1-mini
# Optional global duplicate-signature retry limit for tool calls.
# Default behavior keeps strict low limits except write/edit tools.
# TANDEM_TOOL_LOOP_DUPLICATE_SIGNATURE_LIMIT=200
# Optional per-tool caps. Email delivery defaults to 1 even when general budgets are disabled unless overridden. Define:
# TANDEM_TOOL_BUDGET_DEFAULT=10
# TANDEM_TOOL_BUDGET_BATCH=10
# TANDEM_TOOL_BUDGET_WEBSEARCH=8
# TANDEM_TOOL_BUDGET_READ=8
# TANDEM_TOOL_BUDGET_SEARCH=6
# TANDEM_TOOL_BUDGET_GLOB=4
# Optional websearch duplicate-signature hard cap.
# By default there is no duplicate-signature cap for websearch.
# TANDEM_WEBSEARCH_DUPLICATE_SIGNATURE_LIMIT=5

# Hosted memory ciphertext-at-rest (managed deployments)
# Local/single-user installs should leave these unset.
# TANDEM_MEMORY_ENCRYPTION_REQUIRED=true
# TANDEM_MEMORY_DECRYPT_PROVIDER=google_cloud_kms
# TANDEM_MEMORY_DECRYPT_PRINCIPAL_ID=tandem-hosted-memory-decryptor:<deployment-id>
# TANDEM_MEMORY_GOOGLE_KMS_DECRYPT_COMMAND=/usr/local/bin/tandem-memory-google-kms-decrypt

# benchmark testing
BENCH_PROVIDER=openrouter
BENCH_MODEL=google/gemini-2.5-flash
BENCH_API_KEY=YOUR_BENCH_API_KEY
OPENCODE_ENABLED=1
BENCH_STRICT_COMPARE=0
OPENCODE_BIN=%USERPROFILE%\AppData\Local\pnpm\opencode.CMD
BENCH_TANDEM_FALLBACK_TOOL=1
TANDEM_STATE_DIR=%HOME%\work\tandem-engine\tandem\scripts\bench-js\.bench-state
BENCH_RUNS=3
